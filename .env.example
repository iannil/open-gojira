# Gojira Environment Configuration
# Copy this file to .env and fill in the values.

# ── Database ────────────────────────────────────────────────────────────────
# For local development (SQLite):
DATABASE_URL=sqlite:///data/gojira.db
# For Docker / production (PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://gojira:gojira_secret@postgres:5432/gojira

# PostgreSQL settings (used by docker-compose and backup script)
POSTGRES_DB=gojira
POSTGRES_USER=gojira
POSTGRES_PASSWORD=gojira_secret

# ── Application ─────────────────────────────────────────────────────────────
# CORS allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000"]

# ── External APIs ───────────────────────────────────────────────────────────
# Lixinger API Token (required for market data)
# Obtain from https://www.lixinger.com
LIXINGER_TOKEN=

# ── Docker (optional) ──────────────────────────────────────────────────────
# Frontend port mapping (default: 80)
FRONTEND_PORT=80
