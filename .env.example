# Gojira Environment Configuration
#
# 这个文件是模板 (commit 到 git)。使用方式:
#
# cp .env.example .env
# 然后填真实值 (/.env 是 gitignored)
#
# 后端 backend/app/config.py 通过绝对路径读 <repo_root>/.env,
# 所以 uvicorn (cwd=backend/) / pytest / alembic / docker-compose 都读同一份。
# 不要再创建 backend/.env。

# ── Database ────────────────────────────────────────────────────────────────
# For local development (SQLite):
DATABASE_URL=sqlite:///data/gojira.db
# For Docker / production (PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://gojira:gojira_secret@postgres:5432/gojira

# PostgreSQL settings (used by docker-compose and backup script)
POSTGRES_DB=gojira
POSTGRES_USER=gojira
POSTGRES_PASSWORD=gojira_secret

# ── Application ─────────────────────────────────────────────────────────────
# CORS allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000"]

# ── External APIs ───────────────────────────────────────────────────────────
# Lixinger API Token (required for market data)
# Obtain from https://www.lixinger.com
LIXINGER_TOKEN=

# Zhipu AI (GLM) API key for serenity research module
# Obtain from https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=
# Model name: glm-4.7 (stable, default) / glm-5.1 / glm-5.2 (when API opens)
ZHIPU_MODEL=glm-4.7
# Optional: reverse proxy for mainland China access (e.g. OpenRouter)
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ── Serenity Research Module ───────────────────────────────────────────────
# Monthly token budget soft limit (CNY). Warning emitted when exceeded.
SERENITY_MONTHLY_BUDGET_CNY=100
# Per-run hard limits
SERENITY_MAX_TOKENS=16000
SERENITY_MAX_SEARCHES=30
SERENITY_TIMEOUT=300

# ── Docker (optional) ──────────────────────────────────────────────────────
# Frontend port mapping (default: 80)
FRONTEND_PORT=80
