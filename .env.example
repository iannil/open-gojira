# Gojira 环境变量模板
# 复制为 .env 并填入实际值

# ── 数据源 ───────────────────────────────────────────────────────────
LIXINGER_TOKEN=your_lixinger_token_here

# ── LLM ──────────────────────────────────────────────────────────────
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4.7

# ── 数据库 ───────────────────────────────────────────────────────────
# 默认 SQLite (生产数据持久化在 docker volume 中)
# DATABASE_URL=sqlite:///data/gojira.db

# ── CORS (前端地址) ──────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000"]

# ── 调度器 ───────────────────────────────────────────────────────────
# SCHEDULER_ENABLED=true

# ── Serenity 研究模块 ────────────────────────────────────────────────
# ZHIPU_BASE_URL=
# SERENITY_MONTHLY_BUDGET_CNY=100.0
# SERENITY_MAX_TOKENS=16000
# SERENITY_MAX_SEARCHES=30
# SERENITY_TIMEOUT=300

# ── 频率限制 ─────────────────────────────────────────────────────────
# RATE_LIMIT=60/minute

# ── 自动评估 ─────────────────────────────────────────────────────────
# PLAN_EVALUATOR_ENABLED=true
